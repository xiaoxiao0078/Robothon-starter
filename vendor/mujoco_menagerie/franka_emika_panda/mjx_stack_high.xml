<mujoco model="panda high table stacking">
  <include file="mjx_panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1"/>

  <visual>
    <headlight ambient="0.4 0.4 0.4" diffuse="0.6 0.6 0.6" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.4 0.5" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="grid" builtin="checker" rgb1=".8 .8 .8" rgb2=".6 .6 .6" width="512" height="512"/>
    <material name="grid_mat" texture="grid" texrepeat="4 4" reflectance="0.1"/>
  </asset>

  <worldbody>
    <geom name="floor" size="2.0 2.0 0.125" type="plane" material="grid_mat" pos="0 0 0.18"/>
    <light pos="0 0 3" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <light pos="0.8 0.8 2" dir="-0.5 -0.5 -1" diffuse="0.4 0.4 0.4"/>

    <!-- 方块1: 绿色（底座） -->
    <body name="box1" pos="0.5 0 0.21">
      <freejoint/>
      <geom type="box" name="box1" size="0.02 0.02 0.03" condim="3" friction="2 .03 .003" rgba="0 1 0 1" contype="2" conaffinity="1" solref="0.01 1"/>
    </body>
    <!-- 方块2: 蓝色 -->
    <body name="box2" pos="0.45 0.1 0.21">
      <freejoint/>
      <geom type="box" name="box2" size="0.02 0.02 0.03" condim="3" friction="2 .03 .003" rgba="0 0.3 1 1" contype="2" conaffinity="1" solref="0.01 1"/>
    </body>
    <!-- 方块3: 红色 -->
    <body name="box3" pos="0.55 -0.08 0.21">
      <freejoint/>
      <geom type="box" name="box3" size="0.02 0.02 0.03" condim="3" friction="2 .03 .003" rgba="1 0.2 0 1" contype="2" conaffinity="1" solref="0.01 1"/>
    </body>
  </worldbody>
</mujoco>
